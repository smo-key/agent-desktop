    "package:mac": "tauri build",
    "package:mac:signed": "bash scripts/package-mac-signed.sh"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "3.0.10",
    "@sveltejs/kit": "2.61.1",
    "@sveltejs/vite-plugin-svelte": "7.1.2",
    "@tauri-apps/cli": "2.11.2",
    "@types/node": "25.9.1",
    "jsdom": "^29.1.1",
    "svelte": "5.56.1",
    "svelte-check": "4.5.0",
    "typescript": "5.9.3",
    "vite": "8.0.16",
    "vitest": "4.1.8"
  },
  "dependencies": {
    "@tauri-apps/api": "2.11.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@xterm/addon-fit": "0.11.0",
    "@xterm/addon-webgl": "0.19.0",
    "@xterm/xterm": "6.0.0"
  }
