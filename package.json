{
  "name": "agent-desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run",
    "coverage": "node tools/check-scenario-coverage.mjs",
    "check:gate": "npm run check && npm run test && npm run coverage",
