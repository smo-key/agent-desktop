{
  "name": "agent-desktop",
  "version": "0.1.2",
  "private": true,
  "type": "module",
  "scripts": {
    "setup": "yarn install && yarn setup:hooks && yarn setup:sidecars",
    "setup:hooks": "git config core.hooksPath .githooks",
    "setup:sidecars": "./scripts/fetch-models.sh && ./scripts/fetch-whisper.sh && ./scripts/fetch-llama.sh",
    "postinstall": "git config core.hooksPath .githooks 2>/dev/null || true",
    "dev": "tauri dev",
    "build": "tauri build --config '{\"bundle\":{\"createUpdaterArtifacts\":false}}'",
    "dev:web": "vite dev",
    "build:web": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run",
    "coverage": "node tools/check-scenario-coverage.mjs",
    "lint:storage": "node tools/check-localstorage.mjs",
    "check:gate": "yarn check && yarn test && yarn coverage && yarn lint:storage",
    "tauri": "tauri"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "3.0.10",
    "@sveltejs/kit": "2.61.1",
    "@sveltejs/vite-plugin-svelte": "7.1.2",
    "@tauri-apps/cli": "2.11.2",
    "@types/node": "25.9.1",
    "jsdom": "^29.1.1",
    "svelte": "5.56.1",
    "svelte-check": "4.5.0",
    "typescript": "5.9.3",
    "vite": "8.0.16",
    "vitest": "4.1.8"
  },
  "dependencies": {
    "@tauri-apps/api": "2.11.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "@xterm/addon-fit": "0.11.0",
    "@xterm/addon-webgl": "0.19.0",
    "@xterm/xterm": "6.0.0"
  }
}
