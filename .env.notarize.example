# Credentials for local Tauri builds. Copy to `.env.notarize` (gitignored) and
# fill in. Two consumers source this file:
#   npm run build:local        — needs ONLY the updater-signing vars below.
#   npm run package:mac:signed — also needs the macOS code-sign + notarize vars.
# Tauri's bundler reads these env vars automatically.
#   https://v2.tauri.app/distribute/sign/macos/

# --- Tauri updater signing (REQUIRED for ANY local `tauri build`) -----------
# Because tauri.conf.json sets bundle.createUpdaterArtifacts + a pubkey, every
# build must sign its update artifacts. Generate the keypair once with
# `tauri signer generate`; back up the private key (losing it breaks updates for
# already-installed apps). The value may be the key file path or its contents.
TAURI_SIGNING_PRIVATE_KEY="/absolute/path/to/agent-desktop.key"
TAURI_SIGNING_PRIVATE_KEY_PASSWORD=""   # the password you set, if any

# --- Code-signing identity (only for package:mac:signed) --------------------
# Your "Developer ID Application" identity, exactly as shown by:
#   security find-identity -v -p codesigning
# Use either the full string or the 40-char SHA-1 hash.
APPLE_SIGNING_IDENTITY="Developer ID Application: Your Name (TEAMID)"

# --- Notarization: choose ONE of the two methods below ----------------------

# Method A — App Store Connect API key (RECOMMENDED; no 2FA, CI-friendly).
# Create at https://appstoreconnect.apple.com/access/integrations/api
# (Users and Access > Integrations > App Store Connect API).
#   APPLE_API_ISSUER  = the Issuer ID (UUID shown at the top of that page)
#   APPLE_API_KEY     = the Key ID (10-char string for the key you created)
#   APPLE_API_KEY_PATH= absolute path to the downloaded AuthKey_XXXXXXXXXX.p8
# Store the .p8 OUTSIDE the repo (it can only be downloaded once).
APPLE_API_ISSUER=""
APPLE_API_KEY=""
APPLE_API_KEY_PATH=""

# Method B — Apple ID + app-specific password (simpler to obtain, tied to a person).
# Create an app-specific password at https://account.apple.com (Sign-In & Security
# > App-Specific Passwords). APPLE_TEAM_ID is the 10-char team id from
# https://developer.apple.com/account (Membership details).
#   APPLE_ID="you@example.com"
#   APPLE_PASSWORD="abcd-efgh-ijkl-mnop"   # the app-specific password, not your login
#   APPLE_TEAM_ID="TEAMID1234"

# ============================================================================
# CI release (GitHub Actions) — additional values, set as REPOSITORY SECRETS,
# not in this file. The release workflow (.github/workflows/release.yml) reads
# them to sign + notarize macOS builds and to sign updater bundles. Local
# `package:mac:signed` uses the local keychain identity above and does NOT need
# these; CI has no keychain, so it imports a certificate from secrets instead.
# ============================================================================
#
# macOS signing in CI (tauri-action imports the cert into a temporary keychain):
#   APPLE_CERTIFICATE           base64 of your exported "Developer ID Application"
#                               .p12 (e.g. `base64 -i cert.p12 | pbcopy`)
#   APPLE_CERTIFICATE_PASSWORD  the password you set when exporting the .p12
#   KEYCHAIN_PASSWORD           any throwaway string; names the temp CI keychain
#   APPLE_SIGNING_IDENTITY      same identity string as above
#   plus ONE notary set — Method A (APPLE_API_ISSUER/APPLE_API_KEY/APPLE_API_KEY_PATH)
#   or Method B (APPLE_ID/APPLE_PASSWORD/APPLE_TEAM_ID).
#   If APPLE_CERTIFICATE is unset (forks/PRs), CI still builds — just UNSIGNED.
#
# Updater bundle signing (Tauri updater; generate once with `tauri signer generate`):
#   TAURI_SIGNING_PRIVATE_KEY            the generated private key (store securely;
#                                        losing it breaks updates for installed apps)
#   TAURI_SIGNING_PRIVATE_KEY_PASSWORD   its password, if you set one
