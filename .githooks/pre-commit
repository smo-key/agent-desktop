#!/bin/sh
# agent-desktop pre-commit gate (openspec tasks.md 1.7).
# Fast checks only — type-check, scenario-coverage, and openspec validity.
# (cargo test / vitest are intentionally omitted to keep commits fast; run
# `yarn check:gate` for the full suite.)  Skip once with: git commit --no-verify
set -e

echo "[pre-commit] svelte-check…"
yarn --silent check

echo "[pre-commit] scenario coverage gate…"
node tools/check-scenario-coverage.mjs >/dev/null

echo "[pre-commit] localStorage gate…"
node tools/check-localstorage.mjs >/dev/null

echo "[pre-commit] openspec validate (active changes)…"
openspec validate --changes --strict

echo "[pre-commit] ok"
