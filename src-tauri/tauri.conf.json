{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Agent Desktop",
  "version": "0.3.0",
  "identifier": "com.arthur.agent-desktop",
  "build": {
    "frontendDist": "../build",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev:web",
    "beforeBuildCommand": "npm run build:web"
  },
  "app": {
    "windows": [
      {
        "title": "Agent Desktop",
        "width": 1100,
        "height": 720,
        "maximized": true,
        "resizable": true,
        "fullscreen": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/smo-key/agent-desktop/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQ1NjY4NkQ1RjU3NTkyMEMKUldRTWtuWDExWVptUmRKQ21SL2xYZ3k5Um9EYzJMVHB4NEZFK0tvZXRwTklKb3E2V2VXdnVCNFoK"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "externalBin": [
      "binaries/whisper-cli",
      "binaries/whisper-server",
      "binaries/llama-server"
    ],
    "resources": [
      "models/ggml-tiny.bin",
      "resources/orchestration-mcp.cjs"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    },
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    },
    "macOS": {
      "hardenedRuntime": true,
      "entitlements": "entitlements.plist",
      "infoPlist": "Info.plist"
    }
  }
}
