{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "agent-desktop",
  "version": "0.1.0",
  "identifier": "com.arthur.agent-desktop",
  "build": {
    "frontendDist": "../build",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "agent-desktop",
        "width": 1100,
        "height": 720,
        "maximized": true,
        "resizable": true,
        "fullscreen": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "binaries/whisper-cli",
      "binaries/whisper-server",
      "binaries/llama-server"
    ],
    "resources": [
      "models/ggml-tiny.bin",
      "resources/orchestration-mcp.cjs"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    },
    "macOS": {
      "hardenedRuntime": true,
      "entitlements": "entitlements.plist",
      "infoPlist": "Info.plist"
    }
  }
}
